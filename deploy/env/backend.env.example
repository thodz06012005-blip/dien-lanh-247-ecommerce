# Copy to deploy/env/backend.env and chmod 600.
# The backend receives only application credentials, never MYSQL_ROOT_PASSWORD.

DATABASE_URL=mysql://dl247_app:<inject-mysql-application-password>@db:3306/dien_lanh_247
JWT_ACCESS_SECRET=<inject-random-access-secret-minimum-32-characters>
JWT_REFRESH_SECRET=<inject-random-refresh-secret-minimum-32-characters>
AUDIT_LOG_HASH_SALT=<inject-random-audit-salt-minimum-32-characters>

ADMIN_SEED_EMAIL=admin@dienlanh247.example
ADMIN_SEED_PASSWORD=<inject-one-time-admin-seed-password>
RUN_MIGRATIONS=true
RUN_SEED=false

BACKUP_RETENTION_DAYS=14
LOG_LEVEL=info
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@dienlanh247.example
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
