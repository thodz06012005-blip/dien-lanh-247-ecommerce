# Copy to deploy/env/production.env and chmod 600.
# Replace every <...> value with a secret-manager injection or generated value.

APP_VERSION=1.0.0
USER_DOMAIN=dienlanh247.example
ADMIN_DOMAIN=admin.dienlanh247.example

MYSQL_DATABASE=dien_lanh_247
MYSQL_USER=dl247_app
MYSQL_PASSWORD=<inject-mysql-application-password>
MYSQL_ROOT_PASSWORD=<inject-mysql-root-password>
DATABASE_URL=mysql://dl247_app:<inject-mysql-application-password>@db:3306/dien_lanh_247

JWT_ACCESS_SECRET=<inject-random-access-secret-minimum-32-characters>
JWT_REFRESH_SECRET=<inject-random-refresh-secret-minimum-32-characters>
AUDIT_LOG_HASH_SALT=<inject-random-audit-salt-minimum-32-characters>

ADMIN_SEED_EMAIL=admin@dienlanh247.example
ADMIN_SEED_PASSWORD=<inject-one-time-admin-seed-password>
RUN_MIGRATIONS=true
RUN_SEED=false

BACKUP_RETENTION_DAYS=14
LOG_LEVEL=info
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Optional integrations. Leave unset only when the integration is intentionally disabled.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@dienlanh247.example
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ALERT_WEBHOOK_URL=
