# --- MOCK API ENVIRONMENT CONFIGURATION ---
PORT=3001
NODE_ENV=development

# --- SECURITY & DEV FEATURES ---
# Enable dev-only endpoints (e.g. /dev/reset-db). MUST be false in production.
ENABLE_DEV_ENDPOINTS=false
# Enable default demo accounts. MUST be false in production.
ENABLE_DEMO_ACCOUNTS=false
MOCK_ENABLE_DEMO_ACCOUNTS=false

# --- CORS CONFIGURATION ---
# Comma-separated list of allowed origins. Wildcard "*" is NOT supported when credentials=true.
CORS_ORIGINS=http://localhost:5174,http://localhost:5173,http://127.0.0.1:5174,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173,http://127.0.0.1:5174,http://127.0.0.1:5173

# --- LOGIN RATE LIMIT CONFIGURATION ---
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_PER_EMAIL=5
LOGIN_RATE_LIMIT_MAX_PER_IP=20
LOGIN_RATE_LIMIT_MAX_PER_IP_EMAIL=5
LOGIN_RATE_LIMIT_LOCK_MS=900000
TRUST_PROXY=false
