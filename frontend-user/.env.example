# =============================================================
# CUSTOMER WEB - PUBLIC BUILD-TIME CONFIGURATION
# =============================================================
# Only variables prefixed with VITE_ are exposed to browser code.
# Never place passwords, private keys, JWT secrets or server credentials here.

# Application identity
VITE_APP_NAME="Điện Lạnh 247"
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173

# API configuration
# Mock API:   http://localhost:3001/api/v1
# NestJS API: http://localhost:3000/api/v1
VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_API_TIMEOUT_MS=15000

# Runtime feature switches
VITE_USE_MOCK_API=true
# Legacy compatibility flag. Keep equal to VITE_USE_MOCK_API until removed.
VITE_USE_MOCK=true
VITE_ENABLE_QUERY_DEVTOOLS=false
