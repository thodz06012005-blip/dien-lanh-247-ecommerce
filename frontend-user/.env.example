# =============================================================
# CUSTOMER WEB - PUBLIC BUILD-TIME CONFIGURATION
# =============================================================
# Only variables prefixed with VITE_ are exposed to browser code.
# Never place passwords, private keys, JWT secrets or server credentials here.

# Application identity and canonical production origin
VITE_APP_NAME="Điện Lạnh 247"
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173
VITE_SITE_URL=http://localhost:5173

# Public LocalBusiness structured-data fields
VITE_BUSINESS_PHONE="1900 247"
VITE_SERVICE_AREA="Việt Nam"
VITE_BUSINESS_CITY="Hà Nội"

# Commerce / legacy API configuration
# Mock API:   http://localhost:3001/api/v1
# NestJS API: http://localhost:3000/api/v1
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Managed content API introduced in Phase 5
VITE_CONTENT_API_BASE_URL=http://localhost:3000/api/v1
VITE_API_TIMEOUT_MS=15000

# Optional privacy-safe Core Web Vitals collector. Leave blank to disable network delivery.
# The browser emits a local `dl247:web-vital` CustomEvent even when this is blank.
VITE_WEB_VITALS_ENDPOINT=

# Build-only sitemap source. This value is read by the Node prebuild script and is not bundled.
SITEMAP_API_URL=http://localhost:3000/api/v1

# Runtime feature switches
VITE_USE_MOCK_API=true
# Legacy compatibility flag. Keep equal to VITE_USE_MOCK_API until removed.
VITE_USE_MOCK=true
VITE_ENABLE_QUERY_DEVTOOLS=false
