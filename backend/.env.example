# --- APPLICATION CONFIGURATION ---
NODE_ENV=production
PORT=3000
BCRYPT_SALT_ROUNDS=10

# --- DATABASE CONFIGURATION ---
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://admin_user:secure_password_here@127.0.0.1:3306/ecommerce

# --- SECURITY & AUTHENTICATION ---
# Generate strong secrets using: openssl rand -base64 32
JWT_ACCESS_SECRET=your_super_secure_jwt_access_secret_here
JWT_REFRESH_SECRET=your_super_secure_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS & ORIGINS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=https://dienlanh247.vn,https://admin.dienlanh247.vn
FRONTEND_USER_URL=https://dienlanh247.vn
FRONTEND_ADMIN_URL=https://admin.dienlanh247.vn

# --- INITIAL SEED CONFIGURATION ---
# Default admin credentials created during seed (first-time setup)
ADMIN_EMAIL=admin@dienlanh247.vn
ADMIN_PASSWORD=change_this_to_a_strong_password_before_seeding
ADMIN_NAME=Super Admin
