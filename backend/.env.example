# =============================================================
# NESTJS BACKEND - SERVER-SIDE CONFIGURATION
# =============================================================
# Copy this file to backend/.env for local development.
# Never commit the resulting .env file.

# Application
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=debug
SWAGGER_ENABLED=true
TRUST_PROXY=false

# Database
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:change_me@127.0.0.1:3306/ecommerce

# Authentication and cryptography
# Generate production secrets with a cryptographically secure random generator.
JWT_ACCESS_SECRET=replace_with_random_access_secret_at_least_32_characters
JWT_REFRESH_SECRET=replace_with_random_refresh_secret_at_least_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Browser origins
# Comma-separated values. Never use * with credentials in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
FRONTEND_USER_URL=http://localhost:5173
FRONTEND_ADMIN_URL=http://localhost:5174

# Global request throttling
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Request body limits
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=100kb

# Development-only capabilities
ENABLE_DEV_ENDPOINTS=true
ENABLE_DEMO_ACCOUNTS=true

# Initial database seed
ADMIN_SEED_EMAIL=admin@dienlanh247.vn
ADMIN_SEED_PASSWORD=replace_with_seed_password_at_least_12_characters
ADMIN_NAME=Super Admin

# Login brute-force protection
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_PER_EMAIL=5
LOGIN_RATE_LIMIT_MAX_PER_IP=20
LOGIN_RATE_LIMIT_MAX_PER_IP_EMAIL=5
LOGIN_RATE_LIMIT_LOCK_MS=900000

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_MAX_ENTRIES=1000
AUDIT_LOG_CAPTURE_FAILED_LOGIN=true
AUDIT_LOG_CAPTURE_RBAC_DENIED=true

# Data safety
DANGEROUS_ACTION_CONFIRMATION_REQUIRED=true
SOFT_DELETE_ENABLED=true
