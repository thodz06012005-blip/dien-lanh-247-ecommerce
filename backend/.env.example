# --- APPLICATION CONFIGURATION ---
NODE_ENV=production
PORT=3000
BCRYPT_SALT_ROUNDS=10

# --- DATABASE CONFIGURATION ---
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://admin_user:secure_password_here@127.0.0.1:3306/ecommerce

# --- SECURITY & AUTHENTICATION ---
# Generate strong secrets using: openssl rand -base64 32
JWT_ACCESS_SECRET=placeholder_jwt_access_secret_change_in_production_min_32_characters
JWT_REFRESH_SECRET=placeholder_jwt_refresh_secret_change_in_production_min_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS & ORIGINS ---
# Comma-separated list of allowed origins for CORS. Do NOT use "*" in production.
CORS_ORIGINS=https://admin.example.com,https://www.example.com
ALLOWED_ORIGINS=https://admin.example.com,https://www.example.com
FRONTEND_USER_URL=https://www.example.com
FRONTEND_ADMIN_URL=https://admin.example.com

# --- SECURITY & DEV FEATURES ---
# Enable dev-only features/endpoints. MUST be false in production.
ENABLE_DEV_ENDPOINTS=false
ENABLE_DEMO_ACCOUNTS=false

# --- INITIAL SEED CONFIGURATION ---
# Default admin credentials created during seed (first-time setup)
# ADMIN_SEED_PASSWORD must be at least 12 characters long.
ADMIN_SEED_EMAIL=admin@dienlanh247.vn
ADMIN_SEED_PASSWORD=placeholder_seed_password_must_be_at_least_12_characters_long
ADMIN_NAME=Super Admin

# --- LOGIN RATE LIMIT CONFIGURATION ---
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_PER_EMAIL=5
LOGIN_RATE_LIMIT_MAX_PER_IP=20
LOGIN_RATE_LIMIT_MAX_PER_IP_EMAIL=5
LOGIN_RATE_LIMIT_LOCK_MS=900000
TRUST_PROXY=false
