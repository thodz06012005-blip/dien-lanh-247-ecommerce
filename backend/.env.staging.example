# Backend Staging Configuration Template
NODE_ENV=production
PORT=3000

# Staging PostgreSQL connection url (replace placeholder)
DATABASE_URL="postgresql://<staging_db_user>:<staging_db_password>@<staging_db_host>:<staging_db_port>/<staging_db_name>?schema=public"

# Generate secure random 32+ character secrets for Staging
JWT_ACCESS_SECRET="<generate_secure_random_staging_access_secret_do_not_leak>"
JWT_REFRESH_SECRET="<generate_secure_random_staging_refresh_secret_do_not_leak>"

# Password for seed admin
ADMIN_SEED_PASSWORD="<set_strong_admin_seed_password_for_staging>"

# Allowed Staging URLs
FRONTEND_USER_URL="https://staging.example.com"
FRONTEND_ADMIN_URL="https://staging-admin.example.com"
CORS_ORIGINS="https://staging.example.com,https://staging-admin.example.com"

# Secure cookie config
COOKIE_SECURE=true
ENABLE_DEV_ENDPOINTS=false
ENABLE_DEMO_ACCOUNTS=false
