# --- API CONFIGURATION ---
# Base URL of the backend API (NestJS or Mock API)
# Local Mock API: http://localhost:3001/api/v1
# Local NestJS API: http://localhost:3000/api/v1
VITE_API_BASE_URL=http://localhost:3001/api/v1

# --- RUNTIME MODE ---
# Set to 'true' to use mock-api server or client-side mock fallback
VITE_USE_MOCK=true
VITE_USE_MOCK_API=true

# --- APP CONFIGURATION ---
VITE_APP_NAME="Điện Lạnh 247 - Admin"
